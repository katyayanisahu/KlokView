SECRET_KEY=django-insecure-change-me-in-production-please
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=trackflow_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email — default prints messages to the server console (no real delivery).
# Switch to SMTP (example: Gmail) by uncommenting and filling these in.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=you@gmail.com
# EMAIL_HOST_PASSWORD=your-16-char-google-app-password
# DEFAULT_FROM_EMAIL=TrackFlow <you@gmail.com>

FRONTEND_URL=http://localhost:5173

# Shared secret between the Jira Forge App and this backend. The Forge resolver
# sends it as `Authorization: Bearer <key>` on every call to /jira/* endpoints.
# Set the SAME value on the Forge side with:
#   cd forge-app && forge variables set --encrypt --environment production KLOKVIEW_API_KEY <value>
# Leave blank in local dev to fall open (no auth check) — but you MUST set it
# in production / for any deployment that's reachable from the public internet.
JIRA_FORGE_API_KEY=
