# Copy to `.env` at the repo root and adjust before running `docker compose up`.
# `docker compose` automatically loads this file when named `.env`.

# === Django ===
# Generate one with:  python -c "import secrets;print(secrets.token_urlsafe(64))"
SECRET_KEY=replace-me-with-a-long-random-string
DEBUG=False
# Add your production domain(s) here. Service names `backend` / `frontend` are
# needed for inter-container health/probe traffic.
ALLOWED_HOSTS=localhost,127.0.0.1,backend,frontend

# === Database ===
DB_NAME=trackflow_db
DB_USER=postgres
DB_PASSWORD=postgres
# Host-side port to expose Postgres on (set to "" to keep db internal-only)
DB_PORT_HOST=5432

# === CORS / URLs ===
# In single-host deploys the SPA calls /api/v1 same-origin via nginx so CORS
# is mostly irrelevant. Add the public domain when frontend & backend are on
# different origins.
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
FRONTEND_URL=http://localhost:8080

# === Host port mapping ===
BACKEND_PORT_HOST=8000
FRONTEND_PORT_HOST=8080

# === Frontend build ===
# Leave as /api/v1 for the default single-host setup (nginx proxies to backend).
# Set to https://api.example.com/api/v1 if the API lives on a separate host.
VITE_API_BASE_URL=/api/v1

# === Email (optional — defaults to console backend) ===
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=you@example.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=TrackFlow <no-reply@example.com>

# === Microsoft / Outlook integration (optional) ===
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_TENANT=common
# MS_REDIRECT_URI=https://your-domain.com/api/v1/integrations/outlook/oauth/callback/
# MS_SSO_REDIRECT_URI=https://your-domain.com/api/v1/auth/microsoft/callback/

# === Jira Forge App (optional in local dev, REQUIRED for marketplace deploy) ===
# Generate a strong random secret and set the SAME value on the Forge side:
#   cd forge-app && forge variables set --encrypt --environment production KLOKVIEW_API_KEY <value>
# Leave blank in local dev — the backend will fall open. Set on every
# internet-reachable deployment so only the Forge app can call /jira/* endpoints.
# JIRA_FORGE_API_KEY=
# Optional — pin Jira → KlokView attribution to this email when the Jira user's
# email doesn't match a KlokView account (otherwise falls back to first owner/admin).
# JIRA_DEFAULT_USER_EMAIL=
